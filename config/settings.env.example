# webcode Configuration v0.5
# Copy this file to /etc/webcode/config.env
#
# Set permissions:
#   sudo chmod 600 /etc/webcode/config.env
#   sudo chown root:root /etc/webcode/config.env

# REQUIRED: Cloudflare tunnel name
CF_TUNNEL_NAME="my-tunnel"

# REQUIRED: Base domain (machine identifier + zone)
# Each user gets: {username}-{CF_DOMAIN_BASE}
# e.g., alice-manjaropc.example.com
CF_DOMAIN_BASE="manjaropc.example.com"

# REQUIRED: Path to Cloudflare tunnel credentials JSON file
# Download from Cloudflare dashboard when creating the tunnel.
# Must be root-owned with mode 600.
CF_CREDENTIALS_FILE="/etc/webcode/creds.json"

# REQUIRED: Cloudflare API token with Zone:DNS:Edit permission
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Zone - DNS - Edit
CF_API_TOKEN="your-api-token-here"

# REQUIRED: Cloudflare Zone ID for the domain
# Found in Cloudflare dashboard -> Your domain -> Overview -> API section
CF_ZONE_ID="your-zone-id-here"

# Optional (not recommended): auto-discover users from /etc/passwd when allowlist is empty
# WEBCODE_ALLOW_PASSWD_DISCOVERY=1
