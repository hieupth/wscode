# wscode Configuration v0.3
# Copy this file to /etc/wscode/config.env

# REQUIRED: Cloudflare tunnel name
CF_TUNNEL_NAME="my-tunnel"

# REQUIRED: Base domain
CF_DOMAIN_BASE="code.example.com"

# AUTHENTICATION MODE - Choose one:

# Option A: Token mode (recommended)
CF_TUNNEL_TOKEN="your-tunnel-token-here"

# Option B: Named tunnel credentials
# CF_CREDENTIALS_FILE="/etc/cloudflared/creds.json"

# Optional: Override users list paths
# WSCODE_USERS_ALLOW="/etc/wscode/users.allow"
# WSCODE_USERS_DENY="/etc/wscode/users.deny"

# Optional (not recommended): auto-discover users from /etc/passwd when allowlist is empty
# WSCODE_ALLOW_PASSWD_DISCOVERY=1

# Set permissions:
# sudo chmod 600 /etc/wscode/config.env
# sudo chown root:root /etc/wscode/config.env
